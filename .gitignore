# --- Config sensitif (database, base_url) ---
# application/config/config.php
# application/config/database.php

# --- Sites entry points (config database per-laundry) ---
# sites/

# --- CI3 Logs & Cache ---
application/logs/*
!application/logs/index.html
application/cache/*
!application/cache/index.html

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
.codex/
*.sublime-project
*.sublime-workspace
